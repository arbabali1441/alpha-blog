<section class="page-intro text-center">
  <span class="eyebrow">Topics</span>
  <h1>All categories</h1>
  <p class="section-copy">Browse the library by subject.</p>
</section>

<div class="text-center mb-4">
  <%= paginate @categories %>
</div>

<div class="row justify-content-center">
  <% @categories.each do |category| %>
    <div class="col-md-6 col-lg-4 mb-4">
      <div class="panel-card text-center h-100">
        <h2 class="h4 mb-2"><%= link_to category.name, category_path(category), class: "clean-link story-link" %></h2>
        <p class="small text-muted mb-0"><%= pluralize(category.articles.count, "article") %></p>
      </div>
    </div>
  <% end %>
</div>

<div class="text-center mt-4">
  <%= paginate @categories %>
</div>
