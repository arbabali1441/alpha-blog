<section class="page-intro text-center">
  <span class="eyebrow">Category</span>
  <h1><%= @category.name %></h1>
  <p class="section-copy">Articles grouped under this topic.</p>
</section>

<div class="text-center mb-4">
<% if logged_in? and current_user.admin? %>
  <div class="mb-3">
    <%= link_to "Edit category name", edit_category_path(@category), class: "btn btn-quiet btn-sm" %>
  </div>
<% end %>
  <%= paginate @category_articles%>
</div>
<%= render 'articles/article', obj: @category_articles %>
<div class="text-center">
  <%= paginate @category_articles %>
</div>
