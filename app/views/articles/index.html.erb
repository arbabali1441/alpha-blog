<% featured_article = @articles.first %>
<% grid_articles = @articles.offset_value.to_i.zero? ? @articles.drop(1) : @articles.to_a %>

<div class="mb-5">
  <div class="row align-items-center g-4 mb-5">
    <div class="col-lg-8">
      <span class="eyebrow">Editorial library</span>
      <h1 class="display-4 fw-bold archive-title">Read, save, and discover better articles</h1>
      <p class="lead archive-copy">A calmer archive inspired by Medium and Instapaper: rich article covers, reader mode, highlights, and a personal reading list that feels intentional.</p>
    </div>
    <div class="col-lg-4">
      <div class="reader-shell archive-search-panel p-4 skeleton-surface">
        <%= form_tag search_articles_path, method: :get, class: "row g-2 align-items-end" do %>
          <div class="col-12">
            <label class="form-label">Search title, description, or tags</label>
            <%= text_field_tag 'q[title_or_description_or_tags_name_cont]', params[:q] && params[:q][:title_or_description_or_tags_name_cont], class: "form-control", placeholder: "Try: productivity, ruby, reading" %>
          </div>
          <div class="col-sm-6">
            <%= submit_tag "Search library", class: "btn btn-primary w-100" %>
          </div>
          <div class="col-sm-6">
            <%= link_to "Clear filters", articles_path, class: "btn btn-outline-primary w-100" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="archive-stat-row mb-5">
    <div class="archive-stat-card skeleton-surface">
      <span>Stories</span>
      <strong><%= Article.count %></strong>
    </div>
    <div class="archive-stat-card skeleton-surface">
      <span>Readers</span>
      <strong><%= User.count %></strong>
    </div>
    <div class="archive-stat-card skeleton-surface">
      <span>Topics</span>
      <strong><%= Category.count %></strong>
    </div>
    <div class="archive-stat-card skeleton-surface">
      <span>Reader mode</span>
      <strong>Built in</strong>
    </div>
  </div>

  <div class="row align-items-center mb-4">
    <div class="col-md-8">
      <h2 class="h3 fw-bold mb-1">Featured Articles</h2>
      <p class="text-muted mb-0">Fresh writing from the community with strong covers, clean reading, and save-for-later habits.</p>
    </div>
    <div class="col-md-4 text-end">
      <% if logged_in? %>
        <%= link_to "Write Article", new_article_path, class: "btn btn-primary btn-lg" %>
      <% else %>
        <%= link_to "Start Writing", signup_path, class: "btn btn-primary btn-lg" %>
      <% end %>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-8">
    <% if featured_article && @articles.offset_value.to_i.zero? %>
      <article class="archive-feature-card mb-4 skeleton-surface">
        <div class="archive-feature-media">
          <%= image_tag article_cover_data_uri(featured_article, width: 1280, height: 760), alt: "#{featured_article.title} cover", class: "archive-feature-image" %>
        </div>
        <div class="archive-feature-copy">
          <span class="eyebrow">Featured story</span>
          <h2><%= link_to featured_article.title, article_path(featured_article), class: "clean-link story-link" %></h2>
          <p><%= truncate(featured_article.description, length: 250) %></p>
          <div class="article-stats-row mb-3">
            <span><%= featured_article.user&.username %></span>
            <span><%= pluralize(featured_article.likes.size, "like") %></span>
            <span><%= pluralize(featured_article.bookmarks.size, "save") %></span>
            <span><%= pluralize(featured_article.reading_time_minutes, "min") %></span>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <%= link_to "Read article", article_path(featured_article), class: "btn btn-primary" %>
            <%= link_to "Reader mode", reader_article_path(featured_article), class: "btn btn-outline-primary" %>
          </div>
        </div>
      </article>
    <% end %>

    <div class="article-card-grid">
      <%= render 'article', obj: grid_articles %>
    </div>
  </div>
  
  <div class="col-lg-4">
    <div class="sidebar-panel sticky-top skeleton-surface" style="top: 20px;">
      <div class="sidebar-stack">
        <div>
          <span class="eyebrow">Trending now</span>
          <h5 class="mb-3">Stories getting opened and saved</h5>
        </div>
        <% @trending_articles.each do |article| %>
          <div class="trending-story">
            <div class="trending-rank"><%= @trending_articles.index(article) + 1 %></div>
            <div>
              <div class="fw-bold"><%= link_to truncate(article.title, length: 45), article_path(article), class: "clean-link story-link" %></div>
              <small class="text-muted d-block mt-1">
              <%= pluralize(article.likes.size, "like") %> ·
              <%= pluralize(article.bookmarks.size, "bookmark") %> ·
              <%= pluralize(article.view_count || 0, "view") %>
              </small>
            </div>
          </div>
        <% end %>

        <div class="reader-tip">
          <h6 class="fw-bold">Why Alpha Blog feels professional</h6>
          <ul class="feature-list">
            <li>Reader mode for focused reading.</li>
            <li>Save-for-later and highlights for Instapaper habits.</li>
            <li>Thoughtful discussion and author identity like Medium.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Pagination -->
<div class="d-flex justify-content-center mt-5">
  <%= paginate @articles if @articles.respond_to?(:current_page) %>
</div>
