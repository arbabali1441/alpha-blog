<%= render 'shared/errors', obj: @article %>

<div class="row justify-content-center">
  <div class="col-lg-9">
    <%= form_for(@article, html: { class: "card shadow-sm border-0 p-4 p-lg-5", role: "form" }) do |f| %>
      <div class="form-group">
        <%= f.label :title, class: "form-label" %>
        <%= f.text_field :title, class: "form-control form-control-lg", placeholder: "A clear, compelling title", autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :description, "Article body", class: "form-label" %>
        <%= f.text_area :description, rows: 14, class: "form-control", placeholder: "Write the full article content here" %>
      </div>

      <div class="form-group">
        <%= f.label :tag_list, "Tags", class: "form-label" %>
        <%= f.text_field :tag_list, value: @article.tag_list.join(', '), class: "form-control", placeholder: "productivity, writing, rails" %>
        <small class="text-muted">Separate tags with commas to improve discovery.</small>
      </div>

      <div class="form-group">
        <%= f.label :category_ids, "Categories", class: "form-label d-block" %>
        <div class="category-checklist">
          <%= f.collection_check_boxes :category_ids, Category.all, :id, :name do |cb| %>
            <%= cb.label(class: "checkbox-inline input_checkbox category-pill") { cb.check_box(class: "checkbox") + " " + cb.text } %>
          <% end %>
        </div>
      </div>

      <div class="form-group">
        <%= f.submit class: 'btn btn-primary btn-lg' %>
        <%= link_to "Cancel", articles_path, class: "btn btn-outline-primary btn-lg ms-2" %>
      </div>
    <% end %>
  </div>
</div>
