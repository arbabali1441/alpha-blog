<% obj.each do |article| %>
  <article class="article-card article-grid-card">
    <div class="article-cover-shell">
      <%= image_tag article_cover_data_uri(article, width: 960, height: 620), alt: "#{article.title} cover", class: "article-cover-image" %>
      <div class="article-cover-overlay">
        <span class="story-pill"><%= article.categories.first&.name || article.tag_list.first || "Featured read" %></span>
      </div>
    </div>

    <div class="card-body">
      <div class="article-meta-strip">
        <div class="article-author-meta">
          <% if article.user %>
            <%= link_to gravatar_for(article.user, size: 44), user_path(article.user), class: "clean-link" %>
            <div>
              <div class="fw-bold"><%= link_to article.user.username, user_path(article.user), class: "clean-link story-link" %></div>
              <div class="small text-muted"><%= article.created_at.strftime("%b %d, %Y") %></div>
            </div>
          <% end %>
        </div>
        <div class="reading-chip"><%= pluralize(article.reading_time_minutes, "min") %></div>
      </div>

      <h3 class="card-title article-title mb-2">
        <%= link_to article.title, article_path(article), class: "text-decoration-none clean-link story-link" %>
      </h3>

      <p class="article-excerpt">
        <%= truncate(article.description, length: 150) %>
      </p>

      <% if article.categories.any? || article.tag_list.any? %>
        <div class="story-pills article-pill-row mb-3">
          <% article.categories.first(2).each do |category| %>
            <span class="story-pill"><%= category.name %></span>
          <% end %>
          <% article.tag_list.first(2).each do |tag| %>
            <span class="story-pill story-pill-muted">#<%= tag %></span>
          <% end %>
        </div>
      <% end %>

      <div class="article-stats-row">
        <span><%= pluralize(article.likes.size, "like") %></span>
        <span><%= pluralize(article.bookmarks.size, "save") %></span>
        <span><%= pluralize(article.comments.size, "comment") %></span>
        <span><%= pluralize(article.view_count || 0, "view") %></span>
      </div>

      <div class="article-actions gap-2 d-flex flex-wrap">
        <%= link_to "Read article", article_path(article), class: "btn btn-primary btn-sm" %>
        <%= link_to "Reader mode", reader_article_path(article), class: "btn btn-outline-primary btn-sm" %>

        <% if logged_in? && (current_user == article.user || current_user.admin?) %>
          <%= link_to "Edit", edit_article_path(article), class: "btn btn-warning btn-sm" %>
          <%= link_to "Delete", article_path(article), method: :delete,
                data: { confirm: "Are you sure?" }, class: "btn btn-danger btn-sm" %>
        <% end %>
      </div>
    </div>
  </article>
<% end %>
