<section class="page-intro text-center">
  <span class="eyebrow">Profile</span>
  <h1><%= @user.username %></h1>
  <p class="section-copy">A personal page for published articles, saved reads, and community presence.</p>
</section>

<div class="row justify-content-center mb-4">
  <div class="col-md-4 text-center">
    <%= gravatar_for @user, size: 150 %>
    <% if logged_in? && current_user == @user %>
      <div class="mt-3">
        <%= link_to "Update profile photo", edit_user_path(@user), class: "btn btn-quiet btn-sm" %>
      </div>
    <% end %>
  </div>
</div>

<div class="text-center mb-3">
  <h2 class="h4"><%= @user.username %>'s articles</h2>
</div>
<div class="text-center">
  <%= paginate @user_articles %>
</div>
<%= render 'articles/article', obj: @user_articles %>
<div class="text-center">
  <%= paginate @user_articles %>
</div>
