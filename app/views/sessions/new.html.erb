<section class="auth-shell">
  <div class="auth-card">
    <span class="eyebrow">Welcome back</span>
    <h1>Log in</h1>
    <p class="section-copy">Pick up where you left off in your reading list.</p>

    <%= form_for(:session, html: { role: "form" }, url: login_path) do |f| %>
      <div class="form-group">
        <%= f.label :email %>
        <%= f.email_field :email, class: "form-control", placeholder: "Enter email", autofocus: true %>
      </div>
      <div class="form-group">
        <%= f.label :password %>
        <%= f.password_field :password, class: "form-control", autocomplete: "off", placeholder: "Enter password" %>
        <div class="mt-2">
          <%= link_to "Forgot password?", new_password_reset_path, class: "section-link small" %>
        </div>
      </div>
      <div class="d-flex gap-2 flex-wrap">
        <%= f.submit "Log in", class: 'btn btn-primary btn-lg' %>
        <%= link_to "Back to articles", articles_path, class: "btn btn-quiet btn-lg" %>
      </div>
    <% end %>
  </div>
</section>
