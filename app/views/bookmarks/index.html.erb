<div class="row justify-content-center mt-4">
  <div class="col-lg-10">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
      <div>
        <h1 class="display-5 fw-bold mb-1">Your Reading List</h1>
        <p class="text-muted mb-0">Saved articles you can return to in standard view or reader mode.</p>
      </div>
      <%= link_to "Browse articles", articles_path, class: "btn btn-outline-primary" %>
    </div>

    <% if @bookmarks.any? %>
      <% @bookmarks.each do |bookmark| %>
        <% article = bookmark.article %>
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body">
            <div class="d-flex justify-content-between flex-wrap gap-3">
              <div>
                <h2 class="h4 fw-bold mb-2"><%= link_to article.title, article_path(article), class: "text-decoration-none" %></h2>
                <p class="text-muted mb-2"><%= truncate(article.description, length: 180) %></p>
                <div class="small text-muted">
                  <span><%= article.user.username %></span>
                  <span>· <%= bookmark.created_at.strftime("%B %d, %Y") %></span>
                  <span>· <%= pluralize(article.reading_time_minutes, "minute") %> read</span>
                </div>
              </div>
              <div class="d-flex gap-2 flex-wrap align-items-start">
                <%= link_to "Open", article_path(article), class: "btn btn-primary" %>
                <%= link_to "Reader mode", reader_article_path(article), class: "btn btn-outline-primary" %>
                <%= button_to "Remove", bookmark_path(bookmark), method: :delete, class: "btn btn-outline-primary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <div class="d-flex justify-content-center mt-4">
        <%= paginate @bookmarks if @bookmarks.respond_to?(:current_page) %>
      </div>
    <% else %>
      <div class="reader-shell text-center">
        <h2 class="h4 fw-bold">No saved articles yet</h2>
        <p class="text-muted">Bookmark articles from the feed or article page to build your personal reading queue.</p>
      </div>
    <% end %>
  </div>
</div>
