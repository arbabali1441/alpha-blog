<nav class="navbar navbar-expand-lg navbar-light">
  <div class="container-fluid">
    <%= link_to root_path, class: "navbar-brand fw-bold nav-brand-lockup" do %>
      <span class="brand-mark">A</span>
      <span>Alpha Blog</span>
    <% end %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <%= form_tag search_articles_path, method: :get, class: "d-flex nav-search me-lg-4 my-3 my-lg-0" do %>
        <%= text_field_tag 'q[title_or_description_or_tags_name_cont]', params[:q] && params[:q][:title_or_description_or_tags_name_cont], class: "form-control me-2", placeholder: "Search articles" %>
        <%= submit_tag "Search", class: "btn btn-quiet" %>
      <% end %>

      <ul class="navbar-nav ms-auto align-items-lg-center">
        <li class="nav-item me-lg-2">
          <button type="button" class="btn btn-sm btn-quiet theme-toggle" data-theme-toggle aria-label="Toggle dark mode">
            <span class="theme-toggle-light">Light</span>
            <span class="theme-toggle-dark">Dark</span>
          </button>
        </li>
        <li class="nav-item">
          <%= link_to "Articles", articles_path, class: "nav-link" %>
        </li>

        <li class="nav-item">
          <%= link_to "Users", users_path, class: "nav-link" %>
        </li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="categoriesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Categories
          </a>
          <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="categoriesDropdown">
            <li><%= link_to "All Categories", categories_path, class: "dropdown-item" %></li>
            <% Category.limit(5).each do |category| %>
              <li><%= link_to category.name, category_path(category), class: "dropdown-item" %></li>
            <% end %>
            <% if logged_in? && current_user.admin? %>
              <li><hr class="dropdown-divider"></li>
              <li><%= link_to "Create Category", new_category_path, class: "dropdown-item" %></li>
            <% end %>
          </ul>
        </li>

        <% if logged_in? %>
          <li class="nav-item">
            <%= link_to "Reading List", reading_list_path, class: "nav-link" %>
          </li>

          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="actionsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              Actions
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="actionsDropdown">
              <li><%= link_to "New Article", new_article_path, class: "dropdown-item" %></li>
              <li><hr class="dropdown-divider"></li>
              <li><%= link_to "Your Profile", user_path(current_user), class: "dropdown-item" %></li>
              <li><%= link_to "Edit Profile", edit_user_path(current_user), class: "dropdown-item" %></li>
            </ul>
          </li>
        <% end %>

        <li class="nav-item">
          <% if logged_in? %>
            <div class="dropdown">
              <button class="btn btn-quiet dropdown-toggle" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <%= current_user.username %> <% if current_user.admin? %><span class="badge bg-warning">Admin</span><% end %>
              </button>
              <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                <li><%= link_to "View Profile", user_path(current_user), class: "dropdown-item" %></li>
                <li><%= link_to "Edit Profile", edit_user_path(current_user), class: "dropdown-item" %></li>
                <li><hr class="dropdown-divider"></li>
                <li><%= link_to "Log Out", logout_path, method: :delete, class: "dropdown-item text-danger" %></li>
              </ul>
            </div>
          <% else %>
            <div class="ms-2">
              <%= link_to "Log In", login_path, class: "btn btn-sm btn-quiet me-2" %>
              <%= link_to "Sign Up", signup_path, class: "btn btn-sm btn-primary" %>
            </div>
          <% end %>
        </li>
      </ul>
    </div>
  </div>
</nav>
