<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="description" content="Alpha Blog is an editorial reading platform for saving, discovering, and reading thoughtful articles in a clean, distraction-free interface.">
  <meta name="author" content="Arbab Ali">
  <meta name="theme-color" content="#171717">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Alpha Blog">
  
  <title>Alpha Blog | Read Better</title>
  
  <%= csrf_meta_tags %>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,700&display=swap" rel="stylesheet">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/favicon.ico">

  <!-- Bootstrap 5 CSS (if using CDN) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track' => true %>
</head>
<body class="<%= "#{controller_name}-#{action_name}" %>">
  <!-- Navigation -->
  <%= render 'layouts/navigation' %>
  
  <!-- Flash Messages -->
  <%= render 'layouts/messages' %>
  
  <!-- Main Content -->
  <main class="site-main py-4">
    <div class="container layout-container">
      <%= yield %>
    </div>
  </main>
  
  <!-- Footer -->
  <%= render 'layouts/footer' %>
  
  <!-- JavaScript -->
  <%= javascript_include_tag 'application', 'data-turbolinks-track' => true %>
  
  <!-- Bootstrap 5 JS Bundle (includes Popper) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
