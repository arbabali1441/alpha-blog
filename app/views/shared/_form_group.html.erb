<div class="form-group mb-3">
  <label for="<%= field_name %>" class="form-label"><%= label %></label>
  <% if input_type == 'textarea' %>
    <textarea class="form-control <%= 'is-invalid' if has_error %>" id="<%= field_name %>" name="<%= field_name %>" rows="5" placeholder="<%= placeholder %>"></textarea>
  <% elsif input_type == 'select' %>
    <select class="form-select <%= 'is-invalid' if has_error %>" id="<%= field_name %>" name="<%= field_name %>">
      <option selected><%= placeholder %></option>
      <% options.each do |opt| %>
        <option value="<%= opt %>"><%= opt %></option>
      <% end %>
    </select>
  <% else %>
    <input type="<%= input_type || 'text' %>" class="form-control <%= 'is-invalid' if has_error %>" id="<%= field_name %>" name="<%= field_name %>" placeholder="<%= placeholder %>">
  <% end %>
  <% if error_message.present? %>
    <div class="invalid-feedback d-block"><%= error_message %></div>
  <% end %>
  <small class="form-text text-muted"><%= helper_text %></small>
</div>
